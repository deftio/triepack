# Doxyfile.in -- Doxygen configuration for triepack
# Copyright (c) 2026 M. A. Chatterjee
#
# This file uses CMake variable substitution. Configure via:
#   cmake -DBUILD_DOCS=ON -B build && cmake --build build --target docs

PROJECT_NAME           = "triepack"
PROJECT_NUMBER         = @PROJECT_VERSION@
PROJECT_BRIEF          = "Compressed trie-based dictionary codec"

INPUT                  = @CMAKE_CURRENT_SOURCE_DIR@/include \
                         @CMAKE_CURRENT_SOURCE_DIR@/src
OUTPUT_DIRECTORY       = @CMAKE_CURRENT_BINARY_DIR@/docs

RECURSIVE              = YES
EXTRACT_ALL            = YES

GENERATE_HTML          = YES
GENERATE_LATEX         = NO

FILE_PATTERNS          = *.h *.c *.hpp *.cpp

OPTIMIZE_OUTPUT_FOR_C  = YES

WARN_IF_UNDOCUMENTED   = YES
WARN_AS_ERROR          = FAIL_ON_WARNINGS

QUIET                  = YES

# Exclude test and build directories
EXCLUDE_PATTERNS       = */tests/* */build/*

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO

# Graphs (set to NO if Graphviz is not available)
HAVE_DOT               = NO
